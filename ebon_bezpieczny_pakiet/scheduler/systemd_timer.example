# Przykład jednostki systemd timer dla uruchomienia walidacji EBON
# Pliki do umieszczenia w: ~/.config/systemd/user/

# --- ebon-validate.service ---
[Unit]
Description=EBON — walidacja uczestników

[Service]
Type=oneshot
WorkingDirectory=/ścieżka/do/ebon_bezpieczny_pakiet
ExecStart=/ścieżka/do/.venv/bin/python -m ebon_orchestrator.cli validate \
    --csv data/participants_template.csv \
    --out sample_output/validate
StandardOutput=journal
StandardError=journal

# --- ebon-validate.timer ---
[Unit]
Description=Timer dla walidacji EBON — 60 minut przed startem

[Timer]
OnCalendar=2026-04-10 15:00:00
Persistent=true

[Install]
WantedBy=timers.target

# Polecenia aktywacji:
# systemctl --user daemon-reload
# systemctl --user enable --now ebon-validate.timer
# systemctl --user list-timers
